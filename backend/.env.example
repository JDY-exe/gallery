# Gallery backend runtime (backend only)

NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=8787
API_PUBLIC_URL=http://localhost:8787
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# Temporary local auth mode (you can keep this on while testing routes locally)
ENABLE_MOCK_AUTH=true
MOCK_USER_HEADER=x-demo-user-id

# App secrets (generate real values before production)
# ENCRYPTION_KEY should be a long random secret used to encrypt stored provider tokens.
ENCRYPTION_KEY=replace-with-a-long-random-secret

# Database (optional direct Postgres connection later; current backend uses Supabase JS service client)
DATABASE_URL=postgresql://postgres:password@localhost:5432/gallery

# Supabase (for real auth + hosted Postgres)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# X / Twitter API OAuth + API access
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
# For local X OAuth callbacks, prefer 127.0.0.1 (X docs requirement)
X_REDIRECT_URI=http://127.0.0.1:8787/api/x/connect/callback
X_SCOPES=tweet.read users.read like.read offline.access
X_API_BASE_URL=https://api.x.com/2
X_OAUTH_AUTHORIZE_URL=https://twitter.com/i/oauth2/authorize
X_OAUTH_TOKEN_URL=https://api.x.com/2/oauth2/token

# Mock mode for the X OAuth callback route. Set to false for real X OAuth.
X_ENABLE_MOCK_OAUTH=true
